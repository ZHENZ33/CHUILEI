{
  "manifest_version": 3,
  "name": "垂类产品采集助手",
  "version": "1.0.0",
  "description": "一键采集1688/淘宝/亚马逊产品信息，自动填入垂类产品管理系统",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://detail.1688.com/*",
    "*://*.1688.com/*",
    "*://item.taobao.com/*",
    "*://detail.tmall.com/*",
    "*://www.amazon.com/*",
    "*://www.amazon.co.jp/*",
    "*://www.amazon.co.uk/*",
    "*://www.amazon.de/*",
    "*://*.aliexpress.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://detail.1688.com/*",
        "*://*.1688.com/*",
        "*://item.taobao.com/*",
        "*://detail.tmall.com/*",
        "*://www.amazon.com/*",
        "*://www.amazon.co.jp/*",
        "*://www.amazon.co.uk/*",
        "*://www.amazon.de/*",
        "*://*.aliexpress.com/*"
      ],
      "js": ["collector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://zhenz33.github.io/*",
        "http://localhost/*",
        "http://localhost:5500/*",
        "http://localhost:8080/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:5500/*",
        "http://127.0.0.1:8080/*"
      ],
      "js": ["receiver.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "垂类产品采集助手"
  }
}
